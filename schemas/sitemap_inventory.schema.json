{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sitemap Inventory",
  "type": "object",
  "required": ["domain", "urls"],
  "properties": {
    "domain": {"type": "string"},
    "url_count": {"type": "integer"},
    "urls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {"type": "string"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "lastmod": {"type": "string"},
          "page_type": {"type": "string"},
          "source": {"type": "string"}
        }
      }
    }
  }
}
