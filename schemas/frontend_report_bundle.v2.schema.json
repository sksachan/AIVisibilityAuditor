{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Frontend Report Bundle v2",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "query_workbench",
    "page_level_cms_recommendations",
    "grouped_pr_opportunities",
    "action_checklist"
  ],
  "properties": {
    "schema_version": {
      "const": "query_workbench.v1"
    },
    "contract_version": {
      "const": "page_level_cms_grouped_pr.v2"
    },
    "run_id": {
      "type": "string"
    },
    "brand": {
      "type": "string"
    },
    "market": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "ai_discoverability_hygiene": {
      "$ref": "#/$defs/aiDiscoverabilityHygiene"
    },
    "site_ai_hygiene": {
      "$ref": "#/$defs/aiDiscoverabilityHygiene"
    },
    "evidence_collection": {
      "type": "object"
    },
    "query_workbench": {
      "type": "array"
    },
    "owned_url_readiness": {
      "type": "array",
      "description": "Canonical scored/audited owned URL readiness rows. Its length is the audited owned page count used by executive.headline_metrics.owned_page_count.",
      "items": {
        "$ref": "#/$defs/ownedUrlReadinessRow"
      }
    },
    "source_landscape": {
      "type": "object",
      "properties": {
        "source_citations": {
          "type": "array",
          "description": "Frontend-readable raw citation evidence from AI/SerpAPI observations.",
          "items": {
            "$ref": "#/$defs/sourceCitationRow"
          }
        },
        "observed_non_owned_domains": {
          "type": "array"
        },
        "source_type_counts": {
          "type": "object"
        },
        "competitors": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "page_level_cms_recommendations": {
      "type": "array"
    },
    "grouped_pr_opportunities": {
      "type": "array"
    },
    "action_checklist": {
      "type": "array"
    },
    "tracking_plan": {
      "type": "object"
    },
    "executive": {
      "type": "object",
      "properties": {
        "brandTopicScorecard": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/brandTopicScorecardRow"
          }
        },
        "brand_topic_scorecard": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/brandTopicScorecardRow"
          }
        }
      },
      "additionalProperties": true
    },
    "executive_summary": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "brand_topic_scorecard": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/brandTopicScorecardRow"
          }
        },
        "scorecard_methodology": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "ownedUrlReadinessRow": {
      "type": "object",
      "required": [
        "url",
        "current_geo_score_120",
        "query_mapped"
      ],
      "properties": {
        "url": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "current_geo_score_120": {
          "type": "number"
        },
        "geo_dimensions": {
          "type": "object"
        },
        "query_mapped": {
          "type": "boolean"
        },
        "inventory_source": {
          "type": "string"
        },
        "related_queries": {
          "type": "array"
        },
        "technical_signals": {
          "type": "object"
        },
        "json_ld_present": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "json_ld_block_count": {
          "type": [
            "integer",
            "number",
            "null"
          ]
        },
        "schema_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "sourceCitationRow": {
      "type": "object",
      "required": [
        "url",
        "domain"
      ],
      "properties": {
        "query_id": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "source_domain": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "snippet": {
          "type": "string"
        },
        "citation_text": {
          "type": "string"
        },
        "citation_position": {
          "type": "integer"
        },
        "rank": {
          "type": [
            "integer",
            "number",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "aiDiscoverabilityHygiene": {
      "type": "object",
      "required": [
        "priority",
        "summary",
        "robots_txt",
        "llms_txt",
        "structured_data"
      ],
      "properties": {
        "priority": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "summary": {
          "type": "string"
        },
        "robots_txt": {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "enum": [
                "available",
                "not found",
                "not checked"
              ]
            },
            "url": {
              "type": "string"
            },
            "sitemap_entries_count": {
              "type": "integer"
            }
          },
          "additionalProperties": true
        },
        "llms_txt": {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "enum": [
                "available",
                "not found",
                "not checked"
              ]
            },
            "url": {
              "type": "string"
            },
            "chars": {
              "type": "integer"
            }
          },
          "additionalProperties": true
        },
        "structured_data": {
          "type": "object",
          "required": [
            "owned_pages_total",
            "pages_with_schema",
            "pages_with_json_ld",
            "coverage_pct"
          ],
          "properties": {
            "owned_pages_total": {
              "type": "integer"
            },
            "pages_with_schema": {
              "type": "integer"
            },
            "pages_with_json_ld": {
              "type": "integer"
            },
            "coverage_pct": {
              "type": "number"
            },
            "schema_types_detected": {
              "type": "array",
              "items": {
                "type": "array",
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ]
              }
            },
            "pages_missing_json_ld": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "brandTopicScorecardRow": {
      "type": "object",
      "required": [
        "topic",
        "relativePosition",
        "directionVsLastPeriod",
        "comment"
      ],
      "properties": {
        "topic": {
          "type": "string"
        },
        "aiVisibilityScore": {
          "type": [
            "number",
            "null"
          ]
        },
        "ai_visibility_score": {
          "type": [
            "number",
            "null"
          ]
        },
        "relativePosition": {
          "type": "string"
        },
        "relative_position": {
          "type": "string"
        },
        "directionVsLastPeriod": {
          "type": "string"
        },
        "direction_vs_last_period": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        },
        "queryCount": {
          "type": "integer"
        },
        "query_count": {
          "type": "integer"
        },
        "ownedUrlCount": {
          "type": "integer"
        },
        "owned_url_count": {
          "type": "integer"
        },
        "citationCount": {
          "type": "integer"
        },
        "citation_count": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  }
}
